&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>BiocManager&lt;span style="color:#f92672">::&lt;/span>&lt;span style="color:#a6e22e">install&lt;/span>(&lt;span style="color:#e6db74">&amp;#34;edgeR&amp;#34;&lt;/span>)
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>BiocManager&lt;span style="color:#f92672">::&lt;/span>&lt;span style="color:#a6e22e">install&lt;/span>(&lt;span style="color:#e6db74">&amp;#34;baySeq&amp;#34;&lt;/span>) 
