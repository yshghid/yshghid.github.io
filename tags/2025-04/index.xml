&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>plt&lt;span style="color:#f92672">.&lt;/span>plot(d[&lt;span style="color:#e6db74">&amp;#39;close&amp;#39;&lt;/span>])
