&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>S1 &lt;span style="color:#f92672">&amp;lt;-&lt;/span> &lt;span style="color:#e6db74">&amp;#39;33&amp;#39;&lt;/span>
